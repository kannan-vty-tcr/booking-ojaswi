# ─────────────────────────────────────────────────────────────
# Ojasvi Wellness Booking — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────
PORT=3000

# ── Google Service Account ──────────────────────────────────
# Create a service account in Google Cloud Console:
#   1. Go to https://console.cloud.google.com
#   2. Create a new project (or use an existing one)
#   3. Enable "Google Calendar API" and "Google Sheets API"
#   4. IAM & Admin → Service Accounts → Create Service Account
#   5. Grant it no roles (the calendar/sheet sharing handles access)
#   6. Create a JSON key → download it
#   7. Copy client_email and private_key from the JSON file below

GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Paste the private_key value from the JSON file.
# Keep the literal \n characters (do not convert to real newlines).
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIEow...\n-----END RSA PRIVATE KEY-----\n"

# ── Google Calendar ──────────────────────────────────────────
# The calendar where session bookings will appear.
# Share this calendar with your service account email
# (give it "Make changes to events" permission).
GOOGLE_CALENDAR_ID=hello@ojaswiwellness.com

# ── Google Spreadsheet ───────────────────────────────────────
# One Google Spreadsheet with TWO sheets inside:
#
#   Sheet 1 — "Therapist Capacity"  (admin fills via Google Form)
#     Columns: A=Timestamp | B=Date (YYYY-MM-DD) | C=Slot
#              D=Male Therapists | E=Female Therapists
#
#   Sheet 2 — "Bookings"  (auto-created by the app on first booking)
#     Written automatically — do not edit manually.
#
# Steps to set up the admin Google Form:
#   1. Create a new Google Form at forms.google.com
#   2. Add questions:
#      Q1: Date            → Short answer (admin enters YYYY-MM-DD)
#      Q2: Time Slot       → Dropdown → options: 9:00 AM, 11:00 AM, 1:00 PM, 3:00 PM, 5:00 PM
#      Q3: Male Therapists → Short answer (number)
#      Q4: Female Therapists → Short answer (number)
#   3. Responses → "Link to Sheets" → link to THIS spreadsheet
#      and rename the response sheet to "Therapist Capacity"
#   4. Share the spreadsheet with your service account email
#      (give it "Editor" permission)
#   5. Copy the spreadsheet ID from the URL:
#      https://docs.google.com/spreadsheets/d/SPREADSHEET_ID/edit
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-here
